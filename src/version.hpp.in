// Creates a version number for use in macro comparisons.
//
// Example:
//
// // Check if the version is less than 2.1.0
// if constexpr (vdot::ver::version < vdot::ver::make_version(2, 1, 0)) {
//   // do stuff
// }
//
// Returns an integer which may be used in comparisons
namespace vdot::ver {

inline constexpr auto make_version(
  uint32_t const major,
  uint32_t const minor,
  uint32_t const patch
) noexcept -> uint32_t {
  return ((major) << 16) | ((minor) << 8) | (patch);
}

inline constexpr uint32_t MAJOR{ @PROJECT_VERSION_MAJOR@ };
inline constexpr uint32_t MINOR{ @PROJECT_VERSION_MINOR@ };
inline constexpr uint32_t PATCH{ @PROJECT_VERSION_PATCH@ };

// The version number of this extension. Used for #if comparisons.
// This is generated using the version set in the CMake project macro.
inline constexpr uint32_t version{ make_version(MAJOR, MINOR, PATCH) };

