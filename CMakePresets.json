{
  "version": 5,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 25,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "ninja-default",
      "description": "Default preset that are inherited by all",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "hidden": true
    },


    {
      "name": "gcc-x64",
      "hidden": true,
      "inherits": "ninja-default",
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "g++",
        "CMAKE_C_COMPILER": "gcc"
      }
    },
    {
      "name": "gcc-x64-debug",
      "displayName": "GCC 64bit (Debug)",
      "inherits": "gcc-x64",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "gcc-x64-release",
      "displayName": "GCC 64bit (Release)",
      "inherits": "gcc-x64",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },


    {
      "name": "clang-x64",
      "hidden": true,
      "inherits": "ninja-default",
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "clang++",
        "CMAKE_C_COMPILER": "clang"
      }
    },
    {
      "name": "clang-x64-debug",
      "displayName": "Clang 64bit (Debug)",
      "inherits": "clang-x64",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "clang-x64-release",
      "displayName": "Clang 64bit (Release)",
      "inherits": "clang-x64",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },


    {
      "name": "msvc-x64",
      "hidden": true,
      "inherits": "ninja-default",
      "condition": {
        "lhs": "${hostSystemName}",
        "type": "equals",
        "rhs": "Windows"
      },
      "toolset": {
        "value": "host=x64",
        "strategy": "external"
      },
      "architecture": {
        "value": "x64",
        "strategy": "external"
      },
      "cacheVariables": {
        "CMAKE_C_COMPILER": "cl.exe",
        "CMAKE_CXX_COMPILER": "cl.exe"
      }
    },

    {
      "name": "msvc-x64-debug",
      "displayName": "MSVC 64bit (Debug)",
      "inherits": "msvc-x64",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "msvc-x64-release",
      "displayName": "MSVC 64bit (Release)",
      "inherits": "msvc-x64",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    }
  ]
}
