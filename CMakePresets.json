{
  "version": 5,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 25,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "ninja-default",
      "description": "Default preset that are inherited by all",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "hidden": true
    },


    {
      "name": "gcc",
      "hidden": true,
      "inherits": "ninja-default",
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "g++",
        "CMAKE_C_COMPILER": "gcc"
      }
    },
    {
      "name": "gcc-debug",
      "displayName": "GCC 64bit (Debug)",
      "inherits": "gcc",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "gcc-release",
      "displayName": "GCC 64bit (Release)",
      "inherits": "gcc",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },


    {
      "name": "clang",
      "hidden": true,
      "inherits": "ninja-default",
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "clang++",
        "CMAKE_C_COMPILER": "clang"
      }
    },
    {
      "name": "clang-debug",
      "displayName": "Clang 64bit (Debug)",
      "inherits": "clang",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "clang-release",
      "displayName": "Clang 64bit (Release)",
      "inherits": "clang",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },


    {
      "name": "msvc",
      "hidden": true,
      "inherits": "ninja-default",
      "condition": {
        "lhs": "${hostSystemName}",
        "type": "equals",
        "rhs": "Windows"
      },
      "toolset": {
        "value": "host=x64",
        "strategy": "external"
      },
      "architecture": {
        "value": "x64",
        "strategy": "external"
      },
      "cacheVariables": {
        "CMAKE_C_COMPILER": "cl.exe",
        "CMAKE_CXX_COMPILER": "cl.exe"
      }
    },

    {
      "name": "msvc-debug",
      "displayName": "MSVC 64bit (Debug)",
      "inherits": "msvc",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "msvc-release",
      "displayName": "MSVC 64bit (Release)",
      "inherits": "msvc",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "build-vdot-base",
      "hidden": true,
      "targets": [ "vdot" ]
    },
    {
      "name": "build-vdot-debug",
      "hidden": true,
      "inherits": "build-vdot-base",
      "configuration": "Debug"
    },
    {
      "name": "build-vdot-release",
      "hidden": true,
      "inherits": "build-vdot-base",
      "configuration": "Release"
    },

    { "name": "build-vdot-gcc-debug", "inherits": "build-vdot-debug", "configurePreset": "gcc-debug" },
    { "name": "build-vdot-gcc-release", "inherits": "build-vdot-release", "configurePreset": "gcc-release" },

    { "name": "build-vdot-clang-debug", "inherits": "build-vdot-debug", "configurePreset": "clang-debug" },
    { "name": "build-vdot-clang-release", "inherits": "build-vdot-release", "configurePreset": "clang-release" },

    { "name": "build-vdot-msvc-debug", "inherits": "build-vdot-debug", "configurePreset": "msvc-debug" },
    { "name": "build-vdot-msvc-release", "inherits": "build-vdot-release", "configurePreset": "msvc-release" }

  ]
}
